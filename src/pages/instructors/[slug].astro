---
import Base from '../../layouts/Base.astro';
import { getSupabase, type Instructor, type ClassSession } from '../../lib/supabase';
const { slug } = Astro.params;
const supabase = getSupabase();
const { data } = await supabase.from('instructors').select('*').eq('slug', slug).maybeSingle();
if (!data) return Astro.redirect('/instructors');
const inst = data as Instructor;
const { data: sessionsData } = await supabase.from('class_sessions').select('*, class:classes(*), instructor:instructors(*)').eq('instructor_id', inst.id).gte('starts_at', new Date().toISOString()).order('starts_at').limit(8);
const sessions = (sessionsData ?? []) as ClassSession[];
const personSchema = { "@context": "https://schema.org", "@type": "Person", "name": inst.name, "jobTitle": inst.speciality, "description": inst.bio, "worksFor": { "@type": "LocalBusiness", "name": "Studio Pilates" } };
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Instructors", "item": "https://studio-pilates.vercel.app/instructors" }, { "@type": "ListItem", "position": 3, "name": inst.name, "item": `https://studio-pilates.vercel.app/instructors/${inst.slug}` } ] };
function fmtDate(iso: string) { return new Date(iso).toLocaleString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }); }
---
<Base title={`${inst.name} | Studio Pilates`} description={`${inst.speciality} at Studio Pilates.`} structuredData={[personSchema, breadcrumbs]}>
  <section class="container-x pt-16 pb-10 grid lg:grid-cols-12 gap-10">
    <div class="lg:col-span-5"><div class="aspect-[4/5] rounded-[2rem] overflow-hidden"><img src={inst.photo_url ?? ''} alt={inst.name} class="w-full h-full object-cover" /></div></div>
    <div class="lg:col-span-7">
      <nav class="text-sm text-ink-500 mb-6"><a href="/">Home</a> <span class="mx-2">/</span> <a href="/instructors">Instructors</a> <span class="mx-2">/</span> <span>{inst.name}</span></nav>
      <p class="eyebrow mb-4">{inst.speciality} · {inst.years_experience ?? ''} yrs teaching</p>
      <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight mb-6">{inst.name}</h1>
      <p class="text-ink-700 text-lg leading-relaxed mb-8">{inst.bio}</p>
      {inst.certifications && inst.certifications.length > 0 && (<div class="mb-8"><p class="text-xs uppercase tracking-[0.18em] text-ink-500 mb-3 font-semibold">Certifications</p><ul class="flex flex-wrap gap-2">{inst.certifications.map(c => <li class="text-sm px-3 py-1.5 bg-cream-200 rounded-full text-ink-700">{c}</li>)}</ul></div>)}
      <div class="flex flex-wrap gap-4"><a href="/book" class="btn-primary">Book with {inst.name.split(' ')[0]}</a><a href="/schedule" class="btn-secondary">See the timetable</a></div>
    </div>
  </section>
  <section class="container-x py-14">
    <h2 class="font-[Fraunces] text-3xl mb-6">Next classes with {inst.name.split(' ')[0]}</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {sessions.map(s => (<div class="bg-cream-50 border border-cream-300/60 rounded-2xl p-5"><div class="font-medium text-ink-900">{s.class?.name}</div><div class="text-ink-500 text-sm mb-3">{fmtDate(s.starts_at)}</div><a href={`/book?session=${s.id}`} class="text-terracotta-600 hover:text-terracotta-700 font-medium text-sm">Book →</a></div>))}
      {sessions.length === 0 && <p class="text-ink-500">No upcoming classes — check the full <a href="/schedule" class="underline">schedule</a>.</p>}
    </div>
  </section>
</Base>
