---
import Base from '../../layouts/Base.astro';
import { getSupabase, type Instructor } from '../../lib/supabase';
const supabase = getSupabase();
const { data } = await supabase.from('instructors').select('*').order('name');
const instructors = (data ?? []) as Instructor[];
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Instructors", "item": "https://studio-pilates.vercel.app/instructors" } ] };
---
<Base title="Pilates Instructors | Studio Pilates" description="Meet the certified pilates instructors at Studio Pilates." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Instructors</span></nav>
    <p class="eyebrow mb-4">The team</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-3xl mb-6">Meet Our Pilates Instructors</h1>
  </section>
  <section class="container-x pb-20">
    <div class="grid md:grid-cols-2 gap-6">
      {instructors.map(i => (
        <article class="group grid sm:grid-cols-5 gap-6 bg-cream-50 border border-cream-300/60 rounded-2xl overflow-hidden">
          <a href={`/instructors/${i.slug}`} class="sm:col-span-2 block"><div class="aspect-[4/5] h-full overflow-hidden"><img src={i.photo_url ?? ''} alt={i.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" /></div></a>
          <div class="sm:col-span-3 p-6 flex flex-col"><p class="eyebrow mb-3">{i.speciality}</p><h2 class="font-[Fraunces] text-3xl mb-3">{i.name}</h2><p class="text-ink-500 text-sm leading-relaxed line-clamp-4 mb-4">{i.bio}</p><a href={`/instructors/${i.slug}`} class="mt-auto text-sm font-medium text-terracotta-600">Read bio →</a></div>
        </article>
      ))}
    </div>
  </section>
</Base>
