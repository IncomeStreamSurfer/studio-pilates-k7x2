---
import Base from '../layouts/Base.astro';
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://studio-pilates.vercel.app/contact" } ] };
---
<Base title="Contact Studio Pilates | Visit, Call or Email Us" description="Get in touch with Studio Pilates — visit our London studio on Arbour Lane, call us, or email for bookings and enquiries." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Contact</span></nav>
    <p class="eyebrow mb-4">Say hello</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-2xl mb-6">Get in Touch with Studio Pilates</h1>
    <p class="text-ink-700 text-lg max-w-xl leading-relaxed">For bookings use the <a href="/book" class="underline">booking page</a>. For everything else, send us a note below.</p>
  </section>
  <section class="container-x pb-20 grid lg:grid-cols-5 gap-10">
    <form id="contact-form" class="lg:col-span-3 bg-cream-50 border border-cream-300/60 rounded-2xl p-6 md:p-8 space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block"><span class="text-sm font-medium text-ink-700 block mb-1.5">Name</span><input name="name" required class="w-full rounded-xl border border-cream-300 bg-cream-100 px-4 py-3 text-sm" placeholder="Your name" /></label>
        <label class="block"><span class="text-sm font-medium text-ink-700 block mb-1.5">Email</span><input name="email" type="email" required class="w-full rounded-xl border border-cream-300 bg-cream-100 px-4 py-3 text-sm" placeholder="you@example.com" /></label>
      </div>
      <label class="block"><span class="text-sm font-medium text-ink-700 block mb-1.5">Message</span><textarea name="message" rows="5" required class="w-full rounded-xl border border-cream-300 bg-cream-100 px-4 py-3 text-sm" placeholder="How can we help?"></textarea></label>
      <button type="submit" class="btn-primary">Send →</button>
    </form>
    <aside class="lg:col-span-2 space-y-6">
      <div class="bg-cream-50 border border-cream-300/60 rounded-2xl p-6">
        <h3 class="font-[Fraunces] text-2xl mb-4">Visit the studio</h3>
        <address class="not-italic text-sm text-ink-700 leading-relaxed space-y-1"><div>42 Arbour Lane</div><div>London, SE1 3QX</div><div class="pt-2"><a href="tel:+442079460418">+44 20 7946 0418</a></div><div><a href="mailto:hello@studio-pilates.com">hello@studio-pilates.com</a></div></address>
      </div>
    </aside>
  </section>
  <script is:inline>(function(){const f=document.getElementById('contact-form');f.addEventListener('submit',async e=>{e.preventDefault();const fd=new FormData(f);const r=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.fromEntries(fd.entries()))});if(r.ok){alert('Thanks — we will be in touch.');f.reset();}else{alert('Error');}});})();</script>
</Base>
