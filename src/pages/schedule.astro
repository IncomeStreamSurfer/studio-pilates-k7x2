---
import Base from '../layouts/Base.astro';
import { getSupabase, type ClassSession } from '../lib/supabase';
import { formatGBP } from '../lib/stripe';

const supabase = getSupabase();
const { data } = await supabase
  .from('class_sessions')
  .select('*, class:classes(*), instructor:instructors(*)')
  .gte('starts_at', new Date().toISOString())
  .order('starts_at')
  .limit(120);
const sessions = (data ?? []) as ClassSession[];

const grouped = new Map<string, ClassSession[]>();
for (const s of sessions) {
  const d = new Date(s.starts_at);
  const key = d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(s);
}
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Schedule", "item": "https://studio-pilates.vercel.app/schedule" } ] };
function fmtTime(iso: string) { return new Date(iso).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }); }
---
<Base title="Pilates Class Schedule | Studio Pilates" description="Browse our weekly pilates class schedule. Filter by class type or instructor and book your spot instantly online." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Schedule</span></nav>
    <p class="eyebrow mb-4">The week ahead</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-3xl mb-6">Class Schedule — Find & Book Your Perfect Session</h1>
    <p class="text-ink-700 text-lg max-w-2xl leading-relaxed">All our classes for the next two weeks, live from Supabase.</p>
  </section>
  <section class="container-x pb-20">
    {Array.from(grouped.entries()).map(([day, items]) => (
      <div class="mb-10">
        <h2 class="font-[Fraunces] text-2xl mb-4 pb-3 border-b border-cream-300">{day}</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {items.map(s => (
            <div class="bg-cream-50 border border-cream-300/60 rounded-2xl p-5 hover:shadow-lg transition">
              <div class="flex items-center justify-between mb-3"><span class="font-[Fraunces] text-xl">{fmtTime(s.starts_at)} <span class="text-ink-400 text-sm">– {fmtTime(s.ends_at)}</span></span><span class="text-xs text-terracotta-600 font-medium">{s.class ? formatGBP(s.class.price_pence) : ''}</span></div>
              <h3 class="font-medium mb-1">{s.class?.name ?? 'Pilates Class'}</h3>
              <p class="text-sm text-ink-500 mb-4">with <a href={`/instructors/${s.instructor?.slug ?? ''}`} class="hover:text-terracotta-600">{s.instructor?.name ?? 'Studio Team'}</a></p>
              <div class="flex items-center justify-between"><span class="text-xs text-ink-400">{s.capacity - s.spots_booked} of {s.capacity} spots left</span><a href={`/book?session=${s.id}`} class="text-sm text-terracotta-600 hover:text-terracotta-700 font-medium">Book →</a></div>
            </div>
          ))}
        </div>
      </div>
    ))}
    {grouped.size === 0 && <p class="text-ink-500 text-center py-20">No upcoming classes scheduled. Please check back soon.</p>}
  </section>
</Base>
