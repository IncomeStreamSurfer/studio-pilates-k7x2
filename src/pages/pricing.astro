---
import Base from '../layouts/Base.astro';
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Pricing", "item": "https://studio-pilates.vercel.app/pricing" } ] };
const tiers = [
  { name: 'Drop-in', price: '£28', sub: 'per class', features: ['Any group class', 'Flexible', 'Perfect if travelling'], cta: 'Book a class', href: '/book' },
  { name: '5-class pack', price: '£125', sub: '£25 per class', features: ['Save £15', 'Valid 60 days'], cta: 'Buy 5-pack', href: '/book' },
  { name: '10-class pack', price: '£220', sub: '£22 per class', features: ['Save £60', 'Valid 120 days', 'Freeze up to 14 days'], cta: 'Buy 10-pack', href: '/book', featured: true },
  { name: 'Unlimited', price: '£189', sub: 'per month', features: ['All group classes', 'Priority booking', '10% off privates'], cta: 'Go unlimited', href: '/contact' },
];
---
<Base title="Pilates Class Pricing & Memberships | Studio Pilates" description="View Studio Pilates pricing — drop-in classes, 5 and 10 class packs, and unlimited memberships." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Pricing</span></nav>
    <p class="eyebrow mb-4">Flexible plans</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-3xl mb-6">Pilates Class Pricing — Flexible Options for Every Lifestyle</h1>
  </section>
  <section class="container-x pb-14">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {tiers.map(t => (
        <div class={`rounded-2xl p-7 flex flex-col ${t.featured ? 'bg-ink-900 text-cream-100' : 'bg-cream-50 border border-cream-300/60'}`}>
          {t.featured && <span class="inline-block text-xs uppercase tracking-wider bg-terracotta-500 text-cream-100 px-3 py-1 rounded-full self-start mb-3">Most popular</span>}
          <h2 class="font-[Fraunces] text-2xl mb-1">{t.name}</h2>
          <div class="flex items-baseline gap-2 mb-5"><span class="font-[Fraunces] text-5xl">{t.price}</span><span class="text-sm opacity-70">{t.sub}</span></div>
          <ul class="space-y-3 text-sm mb-8 flex-1">{t.features.map(f => <li class="flex gap-2"><span>✓</span><span>{f}</span></li>)}</ul>
          <a href={t.href} class={`mt-auto inline-flex items-center justify-center py-3 rounded-full text-sm font-medium transition ${t.featured ? 'bg-terracotta-500 hover:bg-terracotta-600 text-cream-100' : 'bg-ink-900 hover:bg-terracotta-600 text-cream-100'}`}>{t.cta} →</a>
        </div>
      ))}
    </div>
  </section>
</Base>
