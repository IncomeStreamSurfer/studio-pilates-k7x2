---
import Base from '../../layouts/Base.astro';
import { getSupabase, type PilatesClass } from '../../lib/supabase';
import { formatGBP } from '../../lib/stripe';
const supabase = getSupabase();
const { data } = await supabase.from('classes').select('*').order('created_at');
const classes = (data ?? []) as PilatesClass[];
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Classes", "item": "https://studio-pilates.vercel.app/classes" } ] };
---
<Base title="Pilates Classes | Studio Pilates" description="Explore our full range of pilates classes — reformer, mat, tower, and more. All levels welcome. Book your spot online today." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Classes</span></nav>
    <p class="eyebrow mb-4">The full menu</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-3xl mb-6">Pilates Classes for Every Body and Level</h1>
  </section>
  <section class="container-x pb-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {classes.map(c => (
        <article class="group bg-cream-50 border border-cream-300/60 rounded-2xl overflow-hidden hover:shadow-xl transition">
          <a href={`/classes/${c.slug}`} class="block">
            <div class="aspect-[4/3] overflow-hidden"><img src={c.image_url ?? ''} alt={`${c.name} at Studio Pilates`} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" /></div>
            <div class="p-6"><div class="flex items-center justify-between mb-2"><span class="text-xs uppercase tracking-wider text-ink-400">{c.level}</span><span class="text-sm font-medium text-terracotta-600">{formatGBP(c.price_pence)}</span></div><h2 class="font-[Fraunces] text-2xl mb-2">{c.name}</h2><p class="text-ink-500 text-sm leading-relaxed line-clamp-3">{c.description}</p></div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Base>
