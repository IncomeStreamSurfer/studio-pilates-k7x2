---
import Base from '../../layouts/Base.astro';
import { getSupabase, type PilatesClass, type ClassSession } from '../../lib/supabase';
import { formatGBP } from '../../lib/stripe';
const { slug } = Astro.params;
const supabase = getSupabase();
const { data: classRow } = await supabase.from('classes').select('*').eq('slug', slug).maybeSingle();
if (!classRow) return Astro.redirect('/classes');
const pClass = classRow as PilatesClass;
const { data: sessionsData } = await supabase.from('class_sessions').select('*, class:classes(*), instructor:instructors(*)').eq('class_id', pClass.id).gte('starts_at', new Date().toISOString()).order('starts_at').limit(6);
const sessions = (sessionsData ?? []) as ClassSession[];
const serviceSchema = { "@context": "https://schema.org", "@type": "Service", "name": pClass.name, "description": pClass.description, "provider": { "@type": "LocalBusiness", "name": "Studio Pilates" }, "offers": { "@type": "Offer", "price": (pClass.price_pence / 100).toFixed(2), "priceCurrency": pClass.currency } };
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Classes", "item": "https://studio-pilates.vercel.app/classes" }, { "@type": "ListItem", "position": 3, "name": pClass.name, "item": `https://studio-pilates.vercel.app/classes/${pClass.slug}` } ] };
function fmtDate(iso: string) { return new Date(iso).toLocaleString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }); }
---
<Base title={`${pClass.name} | Studio Pilates`} description={pClass.description} structuredData={[serviceSchema, breadcrumbs]}>
  <section class="container-x pt-12 pb-10 grid lg:grid-cols-12 gap-10 items-start">
    <div class="lg:col-span-7">
      <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <a href="/classes">Classes</a> <span class="mx-2">/</span> <span>{pClass.name}</span></nav>
      <p class="eyebrow mb-4">{pClass.level} · {pClass.duration_minutes} min</p>
      <h1 class="font-[Fraunces] text-4xl md:text-5xl lg:text-6xl leading-[1.05] mb-6">{pClass.name}</h1>
      <p class="text-ink-700 text-lg leading-relaxed mb-8">{pClass.description}</p>
      <div class="flex flex-wrap gap-4"><a href="/book" class="btn-primary">Book this class · {formatGBP(pClass.price_pence)}</a><a href="/schedule" class="btn-secondary">See full schedule</a></div>
    </div>
    <div class="lg:col-span-5"><div class="aspect-[4/5] rounded-[2rem] overflow-hidden shadow-xl"><img src={pClass.image_url ?? ''} alt={pClass.name} class="w-full h-full object-cover" /></div></div>
  </section>
  <section class="container-x py-14">
    <h2 class="font-[Fraunces] text-3xl md:text-4xl mb-6">Next sessions</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {sessions.map(s => (<div class="bg-cream-50 border border-cream-300/60 rounded-2xl p-5"><div class="font-medium text-ink-900">{fmtDate(s.starts_at)}</div><div class="text-ink-500 text-sm mb-3">with {s.instructor?.name}</div><a href={`/book?session=${s.id}`} class="text-terracotta-600 hover:text-terracotta-700 font-medium text-sm">Book →</a></div>))}
      {sessions.length === 0 && <p class="text-ink-500">No upcoming sessions — check back soon.</p>}
    </div>
  </section>
</Base>
