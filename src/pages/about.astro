---
import Base from '../layouts/Base.astro';
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "About", "item": "https://studio-pilates.vercel.app/about" } ] };
---
<Base title="About Studio Pilates | Our Story & Mission" description="Learn about Studio Pilates — our founding story, values, equipment, and the community we have built around mindful movement." structuredData={breadcrumbs}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>About</span></nav>
    <p class="eyebrow mb-4">Our story</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-[1.05] max-w-3xl mb-6">Our Studio, Our Story — Pilates with Purpose</h1>
  </section>
  <section class="container-x pb-14 grid lg:grid-cols-5 gap-12 items-start">
    <div class="lg:col-span-3 text-lg leading-relaxed text-ink-700 space-y-6">
      <p>Studio Pilates opened its doors on a quiet corner of Arbour Lane in early 2024 with a small team, two reformers, and a stubborn belief: that pilates is at its best when the room is quiet, the class is small, and the instructor is genuinely paying attention.</p>
      <p>Two years on we are still the same studio at heart. The space has grown — twelve reformers, a tower wall, a beautiful high-ceilinged mat room — but the class cap is still eight, the teachers still remember your name, and the practice still centres around breath, precision, and the slow work of getting to know your own body.</p>
      <h2 class="font-[Fraunces] text-3xl md:text-4xl text-ink-900 mt-8 mb-4">What we believe</h2>
      <p>Movement should be intelligent. Teaching should be kind. Strength should feel like sovereignty, not punishment.</p>
      <h2 class="font-[Fraunces] text-3xl md:text-4xl text-ink-900 mt-8 mb-4">The space</h2>
      <p>South-facing windows, reclaimed oak floors, soft clay walls, Balanced Body reformers cleaned between every session, proper showers with real hangers.</p>
      <h2 class="font-[Fraunces] text-3xl md:text-4xl text-ink-900 mt-8 mb-4">Come find us</h2>
      <p>We are on Arbour Lane, five minutes from Borough station. Come in for Beginner Foundations, or book a private session.</p>
    </div>
    <aside class="lg:col-span-2 space-y-6">
      <div class="aspect-[4/5] rounded-[2rem] overflow-hidden"><img src="https://images.unsplash.com/photo-1540206395-68808572332f?auto=format&fit=crop&w=900&q=80" alt="Studio Pilates reformer room" class="w-full h-full object-cover" /></div>
    </aside>
  </section>
</Base>
