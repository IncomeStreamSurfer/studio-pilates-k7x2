---
import Base from '../../layouts/Base.astro';
import { stripe } from '../../lib/stripe';
const url = new URL(Astro.request.url);
const sessionId = url.searchParams.get('session_id');
let summary: { className: string; startsAt: string; instructor: string; amount: string } | null = null;
if (sessionId) {
  try {
    const checkout = await stripe.checkout.sessions.retrieve(sessionId);
    const startsAt = checkout.metadata?.starts_at ? new Date(checkout.metadata.starts_at).toLocaleString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' }) : 'your booked time';
    summary = { className: checkout.metadata?.class_name ?? 'Your pilates class', startsAt, instructor: checkout.metadata?.instructor_name ?? 'our team', amount: checkout.amount_total != null ? '£' + (checkout.amount_total / 100).toFixed(2) : '' };
  } catch (err) { console.warn('[success]', err); }
}
---
<Base title="Booking Confirmed | Studio Pilates" description="Your pilates class is confirmed." noindex>
  <section class="container-x py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center">
      <div class="inline-flex w-20 h-20 rounded-full bg-sage-500/20 text-sage-600 items-center justify-center mb-6 text-3xl">✓</div>
      <p class="eyebrow mb-4">Confirmed</p>
      <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight mb-6">You're Booked! See You on the Mat.</h1>
      <p class="text-ink-700 text-lg leading-relaxed mb-10">Your spot is reserved. A confirmation is on its way to your inbox.</p>
      {summary && (<div class="bg-cream-50 border border-cream-300/60 rounded-2xl p-8 text-left mb-10"><h2 class="font-[Fraunces] text-3xl mb-3">{summary.className}</h2><div class="space-y-2 text-sm text-ink-700"><div><span class="text-ink-400">When:</span> {summary.startsAt}</div><div><span class="text-ink-400">Teacher:</span> {summary.instructor}</div>{summary.amount && <div><span class="text-ink-400">Paid:</span> {summary.amount}</div>}<div><span class="text-ink-400">Studio:</span> 42 Arbour Lane, London SE1 3QX</div></div></div>)}
      <div class="flex flex-wrap gap-4 justify-center"><a href="/schedule" class="btn-primary">Book another class</a><a href="/classes" class="btn-secondary">Explore classes</a></div>
    </div>
  </section>
</Base>
