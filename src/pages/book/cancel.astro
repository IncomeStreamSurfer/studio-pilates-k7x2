---
import Base from '../../layouts/Base.astro';
---
<Base title="Booking Cancelled | Studio Pilates" description="Your booking was not completed. No worries." noindex>
  <section class="container-x py-20">
    <div class="max-w-xl mx-auto text-center">
      <p class="eyebrow mb-4">No charge made</p>
      <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight mb-6">No Worries — Your Spot Is Still Waiting</h1>
      <p class="text-ink-700 text-lg leading-relaxed mb-10">Nothing was charged. Hop back into the schedule whenever you're ready.</p>
      <div class="flex flex-wrap gap-4 justify-center"><a href="/book" class="btn-primary">Try booking again</a><a href="/contact" class="btn-secondary">Get in touch</a></div>
    </div>
  </section>
</Base>
