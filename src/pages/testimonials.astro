---
import Base from '../layouts/Base.astro';
const reviews = [
  { name: 'Hannah W.', rating: 5, since: 'member since 2023', text: 'I have tried most studios in south London. Studio Pilates is the only one where I leave taller, calmer, and actually understanding what I did with my body. The small classes are the whole difference.' },
  { name: 'James O.', rating: 5, since: 'member since 2024', text: 'Marathoner with ongoing hip tightness. Six weeks of reformer twice a week with Sarah fixed what a physio could not in a year.' },
  { name: 'Priya K.', rating: 5, since: 'member since 2024', text: 'I did prenatal classes with Priya from 14 weeks to 38. I cannot overstate how much better my pregnancy was for them. Safe, smart, kind.' },
  { name: 'Tom R.', rating: 5, since: 'member since 2023', text: 'I had always dismissed pilates as not-for-me. One Beginner Foundations class with Emma and I was in. Eighteen months later my back pain is gone.' },
  { name: 'Aisha B.', rating: 5, since: 'member since 2024', text: 'The space itself is beautiful but what I keep coming back for is the teaching. Every instructor actually sees me.' },
  { name: 'Leo M.', rating: 5, since: 'member since 2024', text: 'As a complete beginner I was terrified. Turns out that was unnecessary. Ten classes in and I feel more connected to my body than I have in years.' },
];
const reviewsSchema = reviews.map(r => ({
  "@context": "https://schema.org",
  "@type": "Review",
  "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": 5 },
  "author": { "@type": "Person", "name": r.name },
  "itemReviewed": { "@type": "LocalBusiness", "name": "Studio Pilates" },
  "reviewBody": r.text
}));
const breadcrumbs = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studio-pilates.vercel.app" }, { "@type": "ListItem", "position": 2, "name": "Testimonials", "item": "https://studio-pilates.vercel.app/testimonials" } ] };
---
<Base title="Client Reviews & Testimonials | Studio Pilates" description="Read real reviews from Studio Pilates clients. Hear how reformer, mat, and private sessions have transformed strength, posture, and wellbeing." structuredData={[...reviewsSchema, breadcrumbs]}>
  <section class="container-x pt-16 pb-10">
    <nav class="text-sm text-ink-500 mb-6"><a href="/" class="hover:text-terracotta-600">Home</a> <span class="mx-2">/</span> <span>Testimonials</span></nav>
    <p class="eyebrow mb-4">What clients say</p>
    <h1 class="font-[Fraunces] text-5xl md:text-6xl leading-tight max-w-3xl mb-6">What Our Clients Say About Studio Pilates</h1>
    <p class="text-ink-700 text-lg max-w-2xl leading-relaxed">We are proud of a 4.9-star rating across 340+ Google reviews. Here are some of the stories that matter most.</p>
  </section>
  <section class="container-x pb-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {reviews.map(r => (
        <figure class="rounded-2xl bg-cream-50 border border-cream-300/60 p-6 flex flex-col">
          <div class="flex gap-1 text-terracotta-500 mb-4">★★★★★</div>
          <blockquote class="font-[Fraunces] text-lg leading-snug text-ink-900 mb-5 flex-1">"{r.text}"</blockquote>
          <figcaption class="text-sm"><div class="font-medium text-ink-900">{r.name}</div><div class="text-ink-500 text-xs">{r.since}</div></figcaption>
        </figure>
      ))}
    </div>
  </section>
</Base>
